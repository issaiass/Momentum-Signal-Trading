# .env.example
# Copy to .env and fill in your real values (`cp .env.example .env`) -- .env is gitignored,
# never commit it. Every variable here is optional in the sense that docker-compose.yml
# defaults it to "" or a safe fallback if unset; but leaving a whole feature's block blank
# means that feature is simply inactive (e.g. no SMTP vars = alerts log instead of sending).
# See docs/DEPLOYMENT.md for full setup steps (Azure app registration for Outlook OAuth2,
# IBKR host/port specifics per platform, etc).

# --- Market data vendor API keys (used by core/functions.py's fetch fallback chain) ---
FMP_API_KEY=
EODHD_API_KEY=

# FRED_API_KEY: Fed Funds Rate / CPI for the email reports' "Macro Context" section
# (core/macro_data.py). Optional -- free signup, no cost, ~5 min:
# https://fred.stlouisfed.org/docs/api/api_key.html. Leave unset and the macro section is
# simply omitted from reports, no error.
FRED_API_KEY=

# --- IBKR TWS/Gateway connection ---
# IBKR_HOST: host.docker.internal on Mac/Windows Docker Desktop (default below); on Linux,
# use --network host in docker-compose.yml and set this to 127.0.0.1 instead.
# IBKR_PORT: default for daily-runner's --port (7497 = paper, 7496 = live -- see
# daily-runner --help). An explicit --port on the command line always overrides this.
IBKR_HOST=host.docker.internal
IBKR_PORT=7497

# --- Epic 20: cron schedule (Docker only) -- standard 5-field cron syntax, evaluated in
# the container's TZ (America/New_York). Leave unset to use the defaults shown here.
# Changing these only needs `docker compose up -d` (container recreate), NOT `--build`.
DAILY_RUNNER_CRON=35 9 * * 1-5      # daily-runner: 9:35am ET, weekdays
RISK_MONITOR_CRON=0 9-16 * * 1-5    # risk_monitor.py: hourly, 9am-4pm ET, weekdays

# --- Epic 22: which portfolios get automated risk_monitor.py oversight (Docker only) --
# space-separated names, one cron entry each, must match config.yaml's portfolios: key.
# config.yaml itself supports any number of portfolios for daily-runner automatically;
# this is the ONE place you also need to update if you add portfolios beyond the default.
RISK_MONITOR_PORTFOLIOS=portfolio1  # e.g. "portfolio1 portfolio2 portfolio3"

# --- Epic 12: SMTP alert emails (daily_runner.py send_alert_email) ---
# SMTP_PROVIDER selects the auth mechanism: "gmail" (SMTP_PASS, default) or "outlook"
# (OAuth2 via MS_OAUTH_CLIENT_ID below). Only fill in the block for the provider you use.
SMTP_PROVIDER=gmail

# --- gmail: classic SMTP AUTH with an App Password -------------------------
SMTP_HOST=smtp.gmail.com
# 587 (STARTTLS) is the common default. If every SMTP send times out despite
# correct credentials, try SMTP_PORT=465 (implicit TLS) instead, some networks/
# Docker hosts block 587 at the raw TCP level while leaving 465 open, confirmed
# directly against this project's own container, see core/smtp_auth.py's connect().
SMTP_PORT=465
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your_app_password
ALERT_TO_EMAIL=youraddress@gmail.com
# Optional: per-attempt SMTP connect/send timeout in seconds, default 30 if unset,
# 2 attempts total, see core/smtp_auth.py's connect()/send_with_retry().
# SMTP_TIMEOUT_SECONDS=30

# --- outlook: Outlook.com/Hotmail/Microsoft 365 -----------------------------
# These reject SMTP_PASS-based login outright (basic auth is disabled on those accounts) --
# OAuth2 via MS_OAUTH_CLIENT_ID is required instead. See docs/DEPLOYMENT.md for the Azure
# app registration steps.
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=youraddress@outlook.com
# ALERT_TO_EMAIL=youraddress@outlook.com
# MS_OAUTH_CLIENT_ID=your-application-client-id-guid
# MS_OAUTH_TENANT=consumers

# --- Epic 13: email-commanded remote actions (PAUSE/RESUME/LIQUIDATE/etc.) -- opt-in,
# entirely inactive unless all four of these are set. See docs/EMAIL_COMMANDS.md, and read
# its security model before enabling. Recommend a DEDICATED inbox, not your primary email.
IMAP_HOST=
IMAP_USER=
IMAP_PASS=
TRUSTED_SENDER_EMAIL=
